# === xAI (Grok) API Key ===
# Get one at https://x.ai or the Grok developer console
XAI_API_KEY=xai-your-key-here

# === Clerk Authentication ===
# Create an app at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# === Stripe (Test Mode recommended for development) ===
# Use sk_test_ / pk_test_ keys and a recurring price ID for the $9/mo Pro plan
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...   # Must be a recurring monthly price (created in Stripe Test mode)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...  # Optional but recommended for consistency

# === Optional: Control free tier for anonymous users ===
# NEXT_PUBLIC_MAX_FREE_GENERATIONS=3

# === Admin Access (for /admin page) ===
# Only this Clerk user can access the admin panel to grant trials
# THREADFORGE_OWNER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx

# === X (Twitter) Scheduler (Pro+ only) ===
# Create a Project + App at https://developer.x.com (enable OAuth 2.0 with PKCE + Confidential client)
# Scopes needed: tweet.read tweet.write users.read offline.access
# Set the Callback URL to your /api/x/callback (localhost + prod)
# Preferred env var names (also supports legacy X_CLIENT_ID / X_CLIENT_SECRET):
# X_API_KEY=your-x-oauth2-client-id
# X_API_SECRET=your-x-oauth2-client-secret
# X_REDIRECT_URI=https://yourdomain.com/api/x/callback   # or http://localhost:3000/api/x/callback for dev

# === Cron Secret (for /api/cron/scheduler protection) ===
# Generate a long random string. Used by Vercel Cron + manual triggers.
# CRON_SECRET=change-this-to-a-long-random-value-for-prod
# Note: Scheduler cron in vercel.json is daily for Hobby; see vercel.json for Pro upgrade note.
