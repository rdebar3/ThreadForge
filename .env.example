# === xAI (Grok) API Key ===
# Get one at https://x.ai or the Grok developer console
XAI_API_KEY=xai-your-key-here

# === Clerk Authentication ===
# Create an app at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# === Stripe (Test Mode recommended for development) ===
# Use sk_test_ / pk_test_ keys and a recurring price ID for the $9/mo Pro plan
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...   # Must be a recurring monthly price (created in Stripe Test mode)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...  # Optional but recommended for consistency

# === Optional: Control free tier for anonymous users ===
# NEXT_PUBLIC_MAX_FREE_GENERATIONS=3

# === Admin Access (for /admin page) ===
# Only this Clerk user can access the admin panel to grant trials
# THREADFORGE_OWNER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx
